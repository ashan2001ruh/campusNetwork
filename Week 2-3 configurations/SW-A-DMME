enable
configure terminal
hostname SW-A-DMME

enable secret Cisco
ip domain-name foe.local
no ip domain-lookup
username admin privilege 15 secret Cisco
crypto key generate rsa modulus 1024
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
line vty 0 15
 transport input ssh
 login local
 exec-timeout 10 0
exit
line con 0
 logging synchronous
exit

vlan 30
 name VLAN_DMME
vlan 99
 name MGMT
vlan 100
 name NATIVE
exit

interface Vlan99
 ip address 10.99.99.98 255.255.255.224
 no shutdown
exit
ip default-gateway 10.99.99.97

interface GigabitEthernet0/1
 description PC5
 switchport mode access
 switchport access vlan 30
 spanning-tree portfast
 no shutdown
exit
interface GigabitEthernet0/2
 description PC6
 switchport mode access
 switchport access vlan 30
 spanning-tree portfast
 no shutdown
exit

interface GigabitEthernet0/0
 description Uplink to SW-D-DMME
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 100
 switchport trunk allowed vlan 30,99,100
 no shutdown
exit

end
write memory