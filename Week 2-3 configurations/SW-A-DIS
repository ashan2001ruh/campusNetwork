enable
configure terminal
hostname SW-A-DIS

enable secret Cisco
ip domain-name foe.local
no ip domain-lookup
username admin privilege 15 secret Cisco
crypto key generate rsa modulus 1024
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
line vty 0 15
 transport input ssh
 login local
 exec-timeout 10 0
exit
line con 0
 logging synchronous
exit

vlan 40
 name VLAN_DIS
vlan 99
 name MGMT
vlan 100
 name NATIVE
exit

interface Vlan99
 ip address 10.99.99.4 255.255.255.224
 no shutdown
exit
ip default-gateway 10.99.99.1

interface GigabitEthernet0/1
 description PC7
 switchport mode access
 switchport access vlan 40
 spanning-tree portfast
 no shutdown
exit
interface GigabitEthernet0/2
 description PC8
 switchport mode access
 switchport access vlan 40
 spanning-tree portfast
 no shutdown
exit

interface GigabitEthernet0/0
 description Uplink to SW-CORE
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 100
 switchport trunk allowed vlan 40,99,100
 no shutdown
exit
interface GigabitEthernet1/0
 description Uplink to SW-CORE
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 100
 switchport trunk allowed vlan 40,99,100
 no shutdown
exit

end
write memory
