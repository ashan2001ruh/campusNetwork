enable
configure terminal
hostname SW-CORE
ip routing

enable secret Cisco
ip domain-name foe.local
no ip domain-lookup
username admin privilege 15 secret Cisco
crypto key generate rsa modulus 1024
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
line vty 0 15
 transport input ssh
 login local
 exec-timeout 10 0
exit
line con 0
 logging synchronous
exit

vlan 40
 name VLAN_DIS
vlan 99
 name MGMT
vlan 100
 name NATIVE
exit

interface Loopback0
 ip address 2.2.2.2 255.255.255.255
 ip ospf 1 area 0
exit

interface GigabitEthernet0/0
 description Routed link to R-CORE
 no switchport
 ip address 172.16.1.5 255.255.255.252
 ip ospf 1 area 0
 no shutdown
exit
interface GigabitEthernet1/1
 description Routed link to R-CORE1
 no switchport
 ip address 172.16.1.13 255.255.255.252
 ip ospf 1 area 0
 no shutdown
exit

interface GigabitEthernet1/0
 description Routed peer link to SW-CORE1
 no switchport
 ip address 172.16.0.2 255.255.255.252
 ip ospf 1 area 0
 no shutdown
exit

interface GigabitEthernet0/1
 description Routed link to SW-D-DEIE
 no switchport
 ip address 172.16.10.6 255.255.255.252
 ip ospf 1 area 0
 no shutdown
exit
interface GigabitEthernet0/2
 description Routed link to SW-D-DCEE
 no switchport
 ip address 172.16.20.6 255.255.255.252
 ip ospf 1 area 0
 no shutdown
exit
interface GigabitEthernet0/3
 description Routed link to SW-D-DMME
 no switchport
 ip address 172.16.30.6 255.255.255.252
 ip ospf 1 area 0
 no shutdown
exit

interface GigabitEthernet1/2
 description Trunk to SW-A-DIS
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 100
 switchport trunk allowed vlan 40,99,100
 no shutdown
exit

interface Vlan40
 ip address 10.10.40.253 255.255.255.0
 standby 40 ip 10.10.40.254
 standby 40 preempt
 ip ospf 1 area 0
 no shutdown
exit

interface Vlan99
 ip address 10.99.99.3 255.255.255.224
 standby 99 ip 10.99.99.1
 standby 99 preempt
 no shutdown
exit

router ospf 1
 router-id 2.2.2.2
 log-adjacency-changes
 passive-interface Loopback0
 passive-interface Vlan40
 passive-interface Vlan99
 network 2.2.2.2 0.0.0.0 area 0
 network 10.10.40.0 0.0.0.255 area 0
 network 10.99.99.0 0.0.0.31 area 0
 network 172.16.0.0 0.0.0.3 area 0
 network 172.16.1.4 0.0.0.3 area 0
 network 172.16.1.12 0.0.0.3 area 0
 network 172.16.10.4 0.0.0.3 area 0
 network 172.16.20.4 0.0.0.3 area 0
 network 172.16.30.4 0.0.0.3 area 0
exit

end
write memory
