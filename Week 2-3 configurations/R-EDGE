enable
configure terminal
hostname R-EDGE

enable secret Cisco
ip domain-name foe.local
no ip domain-lookup
username admin privilege 15 secret Cisco
crypto key generate rsa modulus 1024
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
line vty 0 15
 transport input ssh
 login local
 exec-timeout 10 0
exit
line con 0
 logging synchronous
exit

interface Loopback0
 ip address 8.8.8.8 255.255.255.255
exit

interface GigabitEthernet1/0
 description Link to R-CORE1 
 ip address 172.16.2.6 255.255.255.252
 ip nat inside
 ip ospf 1 area 0
 no shutdown
exit

interface GigabitEthernet2/0
 description WAN uplink to NAT cloud 
 ip address dhcp
 ip nat outside
 no shutdown
exit

ip route 0.0.0.0 0.0.0.0 dhcp

router ospf 1
 router-id 8.8.8.8
 log-adjacency-changes
 default-information originate
exit

ip access-list standard NAT-INSIDE
 permit 10.10.10.0 0.0.0.255
 permit 10.10.20.0 0.0.0.255
exit

ip nat inside source list NAT-INSIDE interface GigabitEthernet2/0 overload

end
write memory